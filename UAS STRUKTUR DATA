    //  SORTING
    // --------------------------------------------------------
    void sortingData() {
        cout << "\n[SORTING DATA - Merge Sort O(n log n)]\n";
        cout << "Sort by : 1.Nama  2.Prioritas\nPilih: "; int by; cin >> by;

        Pasien arr[200]; int n;
        daftarPasien.keArray(arr, n);
        if (n == 0) { cout << "Data kosong.\n"; return; }

        bool byNama = (by == 1);
        mergeSort(arr, 0, n-1, byNama);
        cout << "[Merge Sort - O(n log n)] urut " << (byNama ? "nama" : "prioritas") << "\n";

        tampilkanGaris();
        for (int i = 0; i < n; i++)
            cout << "  " << arr[i].nama
                 << " | Prioritas: " << prioritasLabel(arr[i].prioritas)
                 << " | Poli: " << arr[i].poli << "\n";
