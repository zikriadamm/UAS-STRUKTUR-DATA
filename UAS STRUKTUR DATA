    // --------------------------------------------------------
    //  RIWAYAT / STACK
    // --------------------------------------------------------
    void tampilkanRiwayat() {
        cout << "\n[RIWAYAT TINDAKAN - Stack]\n";
        tampilkanGaris();
        riwayat.tampilkan();
    }

    // FIX: undo sekarang konsisten untuk TAMBAH dan HAPUS
    void undoTindakan() {
        if (riwayat.kosong()) { cout << "Tidak ada riwayat.\n"; return; }
        NodeStack* top = riwayat.pop();
        cout << "Undo: [" << top->aksi << "] pada pasien " << top->snapshot.nama << "\n";

        if (top->aksi == "TAMBAH") {
            // FIX: hapus dari KEDUA struktur
            antrian.hapusById(top->snapshot.id);
            daftarPasien.hapus(top->snapshot.id);
            cout << "Pasien dibatalkan dari daftar dan antrian.\n";

        } else if (top->aksi == "HAPUS") {
            // FIX: kembalikan ke KEDUA struktur
            daftarPasien.tambah(top->snapshot);
            antrian.enqueue(top->snapshot);
            cout << "Pasien dikembalikan ke daftar dan antrian.\n";

        } else if (top->aksi == "UPDATE_SESUDAH") {
            // kembalikan versi sebelum update
            // pop lagi untuk ambil UPDATE_SEBELUM
            NodeStack* sebelum = riwayat.pop();
            if (sebelum && sebelum->aksi == "UPDATE_SEBELUM") {
                Pasien* p = daftarPasien.cariById(sebelum->snapshot.id);
                if (p) {
                    *p = sebelum->snapshot;
                    antrian.updateById(sebelum->snapshot);
                    cout << "Data pasien dikembalikan ke versi sebelum update.\n";
                }
                delete sebelum;
            }
        } else {
            cout << "Aksi [" << top->aksi << "] dicatat, tidak bisa di-undo otomatis.\n";
        }
        delete top;
    }

    // --------------------------------------------------------
    //  DOKTER BST
    // --------------------------------------------------------
    void tampilkanDokter() {
        cout << "\n[DIREKTORI DOKTER - BST In-Order]\n";
        tampilkanGaris();
        direkturDokter.tampilkan();
    }

    void cariDokter() {
        cout << "Nama dokter (tanpa Dr.): ";
        string nama; cin.ignore(); getline(cin, nama);
        NodeBST* hasil = direkturDokter.cariDokter(nama);
        if (!hasil) cout << "Dokter tidak ditemukan.\n";
        else cout << "Dr. " << hasil->data.nama
                  << " | " << hasil->data.spesialisasi
                  << " | " << hasil->data.poli << "\n";
    }

    // --------------------------------------------------------
    //  GRAPH POLI
    // --------------------------------------------------------
    void tampilkanGrafikPoli() {
        cout << "\n[RELASI RUJUKAN ANTAR POLI - Graph]\n";
        tampilkanGaris();
        grafikPoli.tampilkan();
    }

    // --------------------------------------------------------
    //  STATISTIK
    // --------------------------------------------------------
    void tampilkanStatistik() {
        cout << "\n[STATISTIK SISTEM]\n";
        tampilkanGaris();
        cout << "  Total pasien terdaftar : " << daftarPasien.size << "\n";
        cout << "  Dalam antrian          : " << antrian.getSize() << "\n";
        cout << "  Log tindakan (stack)   : " << riwayat.getSize() << "\n";
        if (!antrian.kosong()) {
            Pasien next = antrian.peek();
            cout << "  Pasien berikutnya      : " << next.nama
                 << " [" << prioritasLabel(next.prioritas) << "]\n";
        }
    }
};

