// ============================================================
//  STRUCT PASIEN
// ============================================================
struct Pasien {
    int    id;
    string nama;
    int    umur;
    string keluhan;
    int    prioritas;   // 1=darurat, 2=sedang, 3=rendah
    string poli;
};

// ============================================================
//  LINKED LIST
// ============================================================
struct NodeList {
    Pasien    data;
    NodeList* next;
    NodeList(Pasien p) : data(p), next(nullptr) {}
};

class LinkedList {
public:
    NodeList* head;
    int       size;

    LinkedList() : head(nullptr), size(0) {}

    ~LinkedList() {
        NodeList* cur = head;
        while (cur) { NodeList* tmp = cur->next; delete cur; cur = tmp; }
    }

    void tambah(Pasien p) {
        NodeList* baru = new NodeList(p);
        if (!head) { head = baru; }
        else {
            NodeList* cur = head;
            while (cur->next) cur = cur->next;
            cur->next = baru;
        }
        size++;
    }

    bool hapus(int id) {
        if (!head) return false;
        if (head->data.id == id) {
            NodeList* tmp = head; head = head->next; delete tmp; size--; return true;
        }
        NodeList* cur = head;
        while (cur->next && cur->next->data.id != id) cur = cur->next;
        if (!cur->next) return false;
        NodeList* tmp = cur->next;
        cur->next = tmp->next;
        delete tmp; size--; return true;
    }

    Pasien* cariById(int id) {
        NodeList* cur = head;
        while (cur) { if (cur->data.id == id) return &cur->data; cur = cur->next; }
        return nullptr;
    }

    void tampilkan() {
        if (!head) { cout << "  (kosong)\n"; return; }
        NodeList* cur = head;
        while (cur) {
            cout << "  ID:" << cur->data.id
                 << " | " << cur->data.nama
                 << " | Umur:" << cur->data.umur
                 << " | Keluhan:" << cur->data.keluhan
                 << " | Prioritas:" << cur->data.prioritas
                 << " | Poli:" << cur->data.poli << "\n";
            cur = cur->next;
        }
    }

    void keArray(Pasien* arr, int& n) {
        n = 0;
        NodeList* cur = head;
        while (cur) { arr[n++] = cur->data; cur = cur->next; }
    }
};

// ============================================================
//  PRIORITY QUEUE (min-heap)
// ============================================================
class PriorityQueue {
private:
    Pasien* heap;
    int     kapasitas;
    int     ukuran;

    void heapifyUp(int i) {
        while (i > 0) {
            int par = (i - 1) / 2;
            // FIX: jika prioritas sama, ID lebih kecil (daftar lebih dulu) didahulukan
            bool naik = (heap[par].prioritas > heap[i].prioritas) ||
                        (heap[par].prioritas == heap[i].prioritas && heap[par].id > heap[i].id);
            if (naik) { swap(heap[par], heap[i]); i = par; }
            else break;
        }
    }

    void heapifyDown(int i) {
        int terkecil = i, l = 2*i+1, r = 2*i+2;
        auto lebihPrioritas = [&](int a, int b) {
            return heap[a].prioritas < heap[b].prioritas ||
                   (heap[a].prioritas == heap[b].prioritas && heap[a].id < heap[b].id);
        };
        if (l < ukuran && lebihPrioritas(l, terkecil)) terkecil = l;
        if (r < ukuran && lebihPrioritas(r, terkecil)) terkecil = r;
        if (terkecil != i) { swap(heap[i], heap[terkecil]); heapifyDown(terkecil); }
    }

public:
    PriorityQueue(int kap = 100) : kapasitas(kap), ukuran(0) {
        heap = new Pasien[kapasitas];
    }
    ~PriorityQueue() { delete[] heap; }

    bool kosong() { return ukuran == 0; }
    int  getSize() { return ukuran; }

    void enqueue(Pasien p) {
        if (ukuran == kapasitas) { cout << "Antrian penuh!\n"; return; }
        heap[ukuran++] = p;
        heapifyUp(ukuran - 1);
    }

    Pasien dequeue() {
        Pasien top = heap[0];
        heap[0] = heap[--ukuran];
        if (ukuran > 0) heapifyDown(0);
        return top;
    }

    Pasien peek() { return heap[0]; }

    // FIX: hapus pasien dari antrian berdasarkan ID
    bool hapusById(int id) {
        int idx = -1;
        for (int i = 0; i < ukuran; i++) {
            if (heap[i].id == id) { idx = i; break; }
        }
        if (idx == -1) return false;
        heap[idx] = heap[--ukuran];
        if (idx < ukuran) {
            heapifyUp(idx);
            heapifyDown(idx);
        }
        return true;
    }

    // FIX: update data pasien di antrian berdasarkan ID
    bool updateById(Pasien p) {
        for (int i = 0; i < ukuran; i++) {
            if (heap[i].id == p.id) {
                heap[i] = p;
                heapifyUp(i);
                heapifyDown(i);
                return true;
            }
        }
        return false;
    }

    void tampilkan() {
        if (kosong()) { cout << "  Antrian kosong.\n"; return; }
        Pasien* tmp = new Pasien[ukuran];
        for (int i = 0; i < ukuran; i++) tmp[i] = heap[i];
        // bubble sort untuk tampilan
        for (int i = 0; i < ukuran-1; i++)
            for (int j = 0; j < ukuran-i-1; j++)
                if (tmp[j].prioritas > tmp[j+1].prioritas ||
                   (tmp[j].prioritas == tmp[j+1].prioritas && tmp[j].id > tmp[j+1].id))
                    swap(tmp[j], tmp[j+1]);
        for (int i = 0; i < ukuran; i++) {
            string ket = (tmp[i].prioritas==1) ? "[DARURAT]" :
                         (tmp[i].prioritas==2) ? "[SEDANG] " : "[RENDAH] ";
            cout << "  " << ket << " ID:" << tmp[i].id << " " << tmp[i].nama
                 << " | Poli:" << tmp[i].poli << "\n";
        }
        delete[] tmp;
    }
};

// ============================================================
//  STACK — riwayat tindakan
// ============================================================
struct NodeStack {
    string     aksi;
    Pasien     snapshot;
    NodeStack* next;
    NodeStack(string a, Pasien p) : aksi(a), snapshot(p), next(nullptr) {}
};

class Stack {
private:
    NodeStack* top;
    int        ukuran;
public:
    Stack() : top(nullptr), ukuran(0) {}
    ~Stack() { while(top){ NodeStack* t=top->next; delete top; top=t; } }

    void push(string aksi, Pasien p) {
        NodeStack* baru = new NodeStack(aksi, p);
        baru->next = top; top = baru; ukuran++;
    }

    bool kosong() { return top == nullptr; }
    NodeStack* peek() { return top; }
    int getSize() { return ukuran; }

    NodeStack* pop() {
        if (kosong()) return nullptr;
        NodeStack* tmp = top; top = top->next; ukuran--; return tmp;
    }

    void tampilkan() {
        if (kosong()) { cout << "  (riwayat kosong)\n"; return; }
        NodeStack* cur = top;
        int n = 1;
        while (cur) {
            cout << "  " << n++ << ". [" << cur->aksi << "] Pasien: "
                 << cur->snapshot.nama << " (ID:" << cur->snapshot.id << ")\n";
            cur = cur->next;
        }
    }
};

// ============================================================
//  BST — direktori dokter
// ============================================================
struct Dokter {
    string nama;
    string spesialisasi;
    string poli;
};

struct NodeBST {
    Dokter   data;
    NodeBST* kiri;
    NodeBST* kanan;
    NodeBST(Dokter d) : data(d), kiri(nullptr), kanan(nullptr) {}
};

class BST {
private:
    NodeBST* root;

    static string toLower(string s) {
        for (char &c : s) c = (char)tolower((unsigned char)c);
        return s;
    }

    NodeBST* insert(NodeBST* node, Dokter d) {
        if (!node) return new NodeBST(d);
        if (toLower(d.nama) < toLower(node->data.nama)) node->kiri  = insert(node->kiri,  d);
        else                                              node->kanan = insert(node->kanan, d);
        return node;
    }

    NodeBST* cari(NodeBST* node, string nama) {
        if (!node) return nullptr;
        string key    = toLower(nama);
        string curKey = toLower(node->data.nama);
        if (curKey == key) return node;
        if (key < curKey)  return cari(node->kiri, nama);
        return cari(node->kanan, nama);
    }

    void inOrder(NodeBST* node) {
        if (!node) return;
        inOrder(node->kiri);
        cout << "  Dr. " << node->data.nama
             << " | Spesialis: " << node->data.spesialisasi
             << " | Poli: " << node->data.poli << "\n";
        inOrder(node->kanan);
    }

    void hapusTree(NodeBST* node) {
        if (!node) return;
        hapusTree(node->kiri); hapusTree(node->kanan); delete node;
    }

public:
    BST() : root(nullptr) {}
    ~BST() { hapusTree(root); }

    void tambah(Dokter d) { root = insert(root, d); }

    void tampilkan() {
        if (!root) { cout << "  (kosong)\n"; return; }
        inOrder(root);
    }

    NodeBST* cariDokter(string nama) { return cari(root, nama); }
};

// ============================================================
//  GRAPH — relasi rujukan antar poli
// ============================================================
struct EdgeNode {
    string    tujuan;
    EdgeNode* next;
    EdgeNode(string t) : tujuan(t), next(nullptr) {}
};

struct GraphNode {
    string     poli;
    EdgeNode*  edges;
    GraphNode* next;
    GraphNode(string p) : poli(p), edges(nullptr), next(nullptr) {}
};

class Graph {
private:
    GraphNode* head;

    GraphNode* cariNode(string poli) {
        GraphNode* cur = head;
        while (cur) { if (cur->poli == poli) return cur; cur = cur->next; }
        return nullptr;
    }

public:
    Graph() : head(nullptr) {}

    void tambahPoli(string poli) {
        if (cariNode(poli)) return;
        GraphNode* baru = new GraphNode(poli);
        baru->next = head; head = baru;
    }

    void tambahRujukan(string dari, string ke) {
        tambahPoli(dari); tambahPoli(ke);
        GraphNode* node = cariNode(dari);
        EdgeNode* e = new EdgeNode(ke);
        e->next = node->edges; node->edges = e;
    }

    void tampilkan() {
        GraphNode* cur = head;
        while (cur) {
            cout << "  " << cur->poli << " --> ";
            EdgeNode* e = cur->edges;
            if (!e) cout << "(tidak ada rujukan)";
            while (e) { cout << e->tujuan; if (e->next) cout << ", "; e = e->next; }
            cout << "\n";
            cur = cur->next;
        }
    }

    void tampilkanRujukan(string dari) {
        GraphNode* node = cariNode(dari);
        if (!node) { cout << "  Poli tidak ditemukan.\n"; return; }
        cout << "  Dari poli " << dari << " dapat dirujuk ke: ";
        EdgeNode* e = node->edges;
        if (!e) { cout << "(tidak ada rujukan)\n"; return; }
        while (e) { cout << e->tujuan; if (e->next) cout << ", "; e = e->next; }
        cout << "\n";
    }
};

// ============================================================
//  SEARCHING
// ============================================================
static string toLowerGlobal(string s) {
    for (char &c : s) c = (char)tolower((unsigned char)c);
    return s;
}

int linearSearch(Pasien* arr, int n, string nama) {
    string key = toLowerGlobal(nama);
    for (int i = 0; i < n; i++)
        if (toLowerGlobal(arr[i].nama) == key) return i;
    return -1;
}

int binarySearch(Pasien* arr, int n, string nama) {
    string key = toLowerGlobal(nama);
    int lo = 0, hi = n - 1;
    while (lo <= hi) {
        int mid = (lo + hi) / 2;
        string midKey = toLowerGlobal(arr[mid].nama);
        if (midKey == key) return mid;
        else if (midKey < key) lo = mid + 1;
        else hi = mid - 1;
    }
    return -1;
}

// ============================================================
//  SORTING — Merge Sort O(n log n)
// ============================================================
void merge(Pasien* arr, int l, int m, int r, bool byNama) {
    int n1 = m-l+1, n2 = r-m;
    Pasien* L = new Pasien[n1];
    Pasien* R = new Pasien[n2];
    for (int i = 0; i < n1; i++) L[i] = arr[l+i];
    for (int j = 0; j < n2; j++) R[j] = arr[m+1+j];
    int i=0, j=0, k=l;
    while (i<n1 && j<n2) {
        bool pilihL = byNama
            ? (toLowerGlobal(L[i].nama) <= toLowerGlobal(R[j].nama))
            : (L[i].prioritas <= R[j].prioritas);
        if (pilihL) arr[k++] = L[i++]; else arr[k++] = R[j++];
    }
    while (i<n1) arr[k++] = L[i++];
    while (j<n2) arr[k++] = R[j++];
    delete[] L; delete[] R;
}

void mergeSort(Pasien* arr, int l, int r, bool byNama) {
    if (l < r) {
        int m = (l+r)/2;
        mergeSort(arr, l, m, byNama);
        mergeSort(arr, m+1, r, byNama);
        merge(arr, l, m, r, byNama);
    }
}

// ============================================================
//  HELPER VALIDASI INPUT
// ============================================================
int inputAngka(const string& prompt, int min, int max) {
    int val;
    while (true) {
        cout << prompt;
        if (cin >> val && val >= min && val <= max) {
            return val;
        }
        cout << "  Input tidak valid! Masukkan angka antara " << min << " dan " << max << ".\n";
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
    }
}

string inputString(const string& prompt) {
    string val;
    while (true) {
        cout << prompt;
        getline(cin, val);
        // trim spasi
        size_t start = val.find_first_not_of(" \t");
        size_t end   = val.find_last_not_of(" \t");
        if (start != string::npos) val = val.substr(start, end - start + 1);
        if (!val.empty()) return val;
        cout << "  Input tidak boleh kosong!\n";
    }
}

