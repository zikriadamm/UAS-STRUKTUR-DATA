    //  SEARCHING
    // --------------------------------------------------------
    void cariPasien() {
        cout << "\n[CARI PASIEN]\n";
        cout << "1. Linear Search\n2. Binary Search (sort otomatis by nama)\nPilih: ";
        int pilih; cin >> pilih;
        cout << "Nama yang dicari: ";
        string nama; cin.ignore(); getline(cin, nama);

        Pasien arr[200]; int n;
        daftarPasien.keArray(arr, n);
        if (n == 0) { cout << "Data pasien kosong.\n"; return; }

        int idx = -1;
        if (pilih == 1) {
            idx = linearSearch(arr, n, nama);
            cout << "(Linear Search - O(n))\n";
        } else {
            mergeSort(arr, 0, n-1, true);
            idx = binarySearch(arr, n, nama);
            cout << "(Binary Search - O(log n))\n";
        }

        if (idx == -1) cout << "Pasien tidak ditemukan.\n";
        else {
            cout << "Ditemukan!\n"
                 << "  ID: " << arr[idx].id << " | " << arr[idx].nama
                 << " | Umur: " << arr[idx].umur
                 << " | Poli: " << arr[idx].poli
                 << " | Prioritas: " << prioritasLabel(arr[idx].prioritas) << "\n";
        }
    }

