            case 2:  sistem.tampilkanSemuaPasien();     break;
            case 3:  sistem.hapusPasien();              break;
            case 4:  sistem.updatePasien();             break;
            case 5:  sistem.tampilkanAntrian();         break;
            case 6:  sistem.panggilPasienBerikutnya();  break;
            case 7:  sistem.cariPasien();               break;
            case 8:  sistem.sortingData();              break;
            case 9:  sistem.tampilkanRiwayat();         break;
            case 10: sistem.undoTindakan();             break;
            case 11: sistem.tampilkanDokter();          break;
            case 12: sistem.cariDokter();               break;
            case 13: sistem.tampilkanGrafikPoli();      break;
            case 14: sistem.tampilkanStatistik();       break;
            case 0:  cout << "Terima kasih!\n";        break;
            default: cout << "Pilihan tidak valid.\n";
        }
    } while (pilih != 0);

    return 0;
}

